\makeatletter
\renewcommand{\fonte}[2][FONTE]{%
    \M@gettitle{#2}%
    \memlegendinfo{#2}%
    \par
    \begingroup
    \@parboxrestore
    \if@minipage
    \@setminipage
    \fi
    \ABNTEXfontereduzida
    \configureseparator\vspace{0cm}
    \@makecaption{\ABNTEXfontereduzida #1}{\ignorespaces\ABNTEXfontereduzida
    #2}\vspace{-.5cm}
    \endgroup}
\makeatother

